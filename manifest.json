{
  "manifest_version": 2,
  "name": "PageToMD",
  "version": "1.3.0",
  "description": "Turn any web page into clean, ready-to-use Markdown. Copy to clipboard or download as a .md file in one click.",
  "author": "Super Z",
  "permissions": [
    "tabs",
    "activeTab",
    "clipboardWrite",
    "contextMenus",
    "storage",
    "downloads"
  ],
  "optional_permissions": [
    "<all_urls>",
    "https://api.github.com/*",
    "https://content.dropboxapi.com/*",
    "https://api.dropboxapi.com/*",
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Convert to Markdown"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+M",
        "mac": "Alt+M"
      },
      "description": "Open Markdown converter popup"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pagetomd@superz.dev",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
